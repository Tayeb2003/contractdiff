# Server port
PORT=3001

# Frontend URL (used for CORS)
# In production, set this to your frontend domain
APP_URL=http://localhost:3000

# JWT secret — Used to sign auth tokens
# Generate a strong random string for production
JWT_SECRET=contractdiff-dev-secret-change-in-production

# ─────────────────────────────────────────────────────────────
# AI PROVIDER — Bring Your Own Key
# ContractDiff works with Google Gemini, OpenAI, or NVIDIA NIM.
# Set ONE of the keys below on the server. Any user who has not
# set their own key in Settings will use this server-level provider.
# Priority if multiple are set: GEMINI -> OPENAI -> NVIDIA
# ─────────────────────────────────────────────────────────────

# Option 1 — Google Gemini (default)
# Get a key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Option 2 — OpenAI
# Get a key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Option 3 — NVIDIA NIM (OpenAI-compatible)
# Get a key at: https://build.nvidia.com/
NVIDIA_API_KEY=
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
