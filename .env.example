# ==========================================
# Server config
# ==========================================
PORT=3001
APP_URL=http://localhost:3000
# Generate a strong random secret, e.g.:
#   openssl rand -hex 32
# Do not use the old hardcoded default in production.
JWT_SECRET=

# ==========================================
# Security
# ==========================================
# Key used to encrypt users' third-party AI keys at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
# If unset, API keys are stored UNENCRYPTED (a warning is logged).
API_KEY_ENCRYPTION_SECRET=
# Opt-in only: when 'true', /forgot-password echoes the reset link in the
# response for local dev. NEVER enable in production or any shared/staging
# environment — it re-opens an account-takeover path.
RESET_DEV_LINK=false

# Number of trusted reverse-proxy hops in front of the app (Render/Cloudflare/
# nginx). Needed so per-IP rate limiting sees the real client, not the proxy.
# TRUST_PROXY=1

# ==========================================
# Frontend (Vite) config
# ==========================================
# API base URL for production. Defaults to '/api' (same-origin).
# Change to full URL if frontend and backend are on different domains.
# VITE_API_URL=https://api.contractdiff.app

# ==========================================
# Turso Database (for Wasmer Edge deployment)
# ==========================================
# Create a free Turso database at https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-token

# ==========================================
# Email (for password reset)
# ==========================================
# Resend: https://resend.com (free tier: 100 emails/day)
# RESEND_API_KEY=re_...
# EMAIL_FROM=noreply@yourdomain.com

# ==========================================
# CORS — comma-separated origins allowed
# ==========================================
ALLOWED_ORIGINS=

# ==========================================
# AI Provider models (optional overrides)
# ==========================================
# OPENAI_MODEL=gpt-4o-mini
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# ==========================================
# Server-provided default AI key (optional)
# ==========================================
# If a user has not set their own key, the app falls back to this server key
# so it works out of the box. Leave unset to require each user's own key.
# DEFAULT_AI_KEY=
# DEFAULT_AI_PROVIDER=gemini
